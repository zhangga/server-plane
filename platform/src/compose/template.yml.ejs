services:

  redis:
    image: redis:7
    restart: always
    command: ["redis-server", "--requirepass", "<%= redisPassword %>"]
    ports:
      - "<%= hostPorts.redis %>:6379"
    volumes:
      - redis_data:/data
    networks:
      app_net:
        ipv4_address: <%= ips.redis %>

  mongodb:
    image: mongo:7
    restart: always
    ports:
      - "<%= hostPorts.mongo %>:27017"
    environment:
      MONGO_INITDB_ROOT_USERNAME: <%= mongoUsername %>
      MONGO_INITDB_ROOT_PASSWORD: "<%= mongoPassword %>"
    volumes:
      - mongo_data:/data/db
    networks:
      app_net:
        ipv4_address: <%= ips.mongo %>

  etcd:
    image: quay.io/coreos/etcd:v3.6.0
    restart: always
    command: >
      /usr/local/bin/etcd
      --name node1
      --data-dir /etcd-data
      --listen-client-urls http://0.0.0.0:2379
      --advertise-client-urls http://etcd:2379
      --auth-token simple
    volumes:
      - etcd_data:/etcd-data
    networks:
      app_net:
        ipv4_address: <%= ips.etcd %>

  etcd-init:
    image: anldisr/etcdctl:latest
    depends_on:
      - etcd
    entrypoint:
      - /bin/sh
      - -c
    command: |
      set -e
      export ETCDCTL_API=3

      echo "wait etcd..."
      until etcdctl --endpoints=http://etcd:2379 endpoint health; do
        sleep 1
      done

      if etcdctl --endpoints=http://etcd:2379 auth status | grep -q true; then
        echo "auth already enabled"
        exit 0
      fi

      etcdctl --endpoints=http://etcd:2379 user add root:<%= etcdPassword %>
      etcdctl --endpoints=http://etcd:2379 role add root
      etcdctl --endpoints=http://etcd:2379 role grant-permission root readwrite --prefix /
      etcdctl --endpoints=http://etcd:2379 user grant-role root root
      etcdctl --endpoints=http://etcd:2379 auth enable

      echo "etcd auth enabled"
    networks:
      app_net:
        ipv4_address: <%= ips.etcdInit %>

  tgateserver:
    image: harbor-sh.dailygn.com/pst/tgateserver:<%= imageTag %>
    restart: always
    depends_on:
      - etcd-init
      - redis
      - mongodb
    working_dir: /tgate_server
    volumes:
      - ./external_config/entrypoint.sh:/tgate_server/entrypoint.sh:ro
      - external_storage:/external_storage
      - ./external_config:/external_config
    entrypoint: ["bash", "/tgate_server/entrypoint.sh"]
    command:
      - "-javaagent:lib/oasis-server-framework.jar"
      - -cp
      - "./:patches/classpath/:lib/*"
      - --enable-preview
      - -Xmx2g
      - -Xms1g
      - "-XX:-OmitStackTraceInFastThrow"
      - "-XX:ReservedCodeCacheSize=256m"
      - "-XX:+UnlockExperimentalVMOptions"
      - "-XX:+UseCompactObjectHeaders"
      - "-XX:+UseG1GC"
      - "-XX:MaxGCPauseMillis=100"
      - "-Xlog:gc*=info,safepoint*=info,age*=trace:file=logs/jvm.log:time,uptime,tid,level,tags:filecount=20,filesize=100M"
      - "-XX:ErrorFile=logs/hs_err_%p.log"
      - "-XX:+HeapDumpOnOutOfMemoryError"
      - "-XX:HeapDumpPath=logs"
      - --add-opens
      - java.base/java.lang=ALL-UNNAMED
      - --add-opens
      - java.base/java.util.concurrent=ALL-UNNAMED
      - --add-opens
      - java.base/jdk.internal.misc=ALL-UNNAMED
      - -Dmodule.name=tgate_0
      - -Dfile.encoding=UTF-8
      - -Duser.timezone=Asia/Shanghai
      - -Dlog4j2.configurationFile=./log4j2.xml
      - -Dio.netty.maxDirectMemory=1073741824
      - oasis.st.tgate.Main
    ports:
      - "<%= hostPorts.tgate %>:12001"
    environment:
      ETCD_ADDR: http://<%= ips.etcd %>:2379
      ETCD_NS: /self_deploy/
      ETCD_USER: root
      ETCD_PWD: ""
      POD_NAME: tgateserver
      SERVICE: "tgate"
      SERVER_ID: "0"
    networks:
      app_net:
        ipv4_address: <%= ips.tgate %>

