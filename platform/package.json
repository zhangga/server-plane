{
  "name": "@pst/platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build --config web/vite.config.ts",
    "dev:local": "tsx scripts/dev-local.ts",
    "dev:api": "tsx src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:worker": "tsx src/worker.ts",
    "render": "tsx scripts/render.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@tanstack/react-query": "^5.100.14",
    "bullmq": "^5.77.6",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.14",
    "vitest": "^2.1.5"
  }
}
